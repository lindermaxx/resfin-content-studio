# ResFin Content Studio — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com suas chaves
# NUNCA commite o .env.local no Git

# Anthropic Claude (Copy Studio / Leandro Ladeira)
# Obter em: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=

# Google AI (Research com Gemini + Geração de Imagem com Imagen/NanoBanana)
# Obter em: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# Modelo Google para geração de imagem
GOOGLE_IMAGE_MODEL=gemini-3-pro-image-preview

# Modelo Google para pesquisa / research
GOOGLE_TEXT_MODEL=gemini-2.0-flash

# OpenAI DALL-E 3 (fallback de imagem — opcional)
# Obter em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Vercel KV (Pipeline de posts — Pending / Approved / Published)
# Copiar do Vercel Dashboard → Storage → seu banco KV → tab ".env.local"
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
